      "SpotBaseUrl": "https://api.binance.com",
      "FuturesBaseUrl": "https://fapi.binance.com",
      "MaxWeightPerMinute": 2400,
      "WeightBudgetPercent": 40,
      "RequestDelayMs": 50
    },
